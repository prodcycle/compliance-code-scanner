{
  "name": "@prodcycle/compliance-code-scanner",
  "version": "1.0.0",
  "description": "GitHub Action to scan PR changes for compliance violations via ProdCycle API",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ __tests__/",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "all": "npm run type-check && npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "github-action",
    "compliance",
    "soc2",
    "hipaa",
    "security",
    "prodcycle"
  ],
  "author": "ProdCycle <support@prodcycle.com> (https://prodcycle.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/prodcycle/compliance-code-scanner.git"
  },
  "homepage": "https://github.com/prodcycle/compliance-code-scanner#readme",
  "bugs": {
    "url": "https://github.com/prodcycle/compliance-code-scanner/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.0",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.0"
  }
}
